# ── Groww Broker API ──
# JWT token from Groww (requires roles: order-basic, live_data-basic, etc.)
# Get this from your Groww session after login
GROWW_API_KEY=your_groww_jwt_token_here

# ── News API ──
# Free tier: https://newsapi.org/register
NEWS_API_KEY=your_newsapi_key_here

# ── Google Cloud (Gemini 2.5 Pro) ──
# Path to your Google Cloud service account JSON credentials file
GOOGLE_APPLICATION_CREDENTIALS=your-service-account.json
GOOGLE_CLOUD_PROJECT=your-gcp-project-id
GOOGLE_CLOUD_LOCATION=us-central1
